# Server Settings(Required)
PORT=3000
HTTPS_PORT=3443
# Node_ENV=deployment | production
NODE_ENV=development

# Zoom Video SDK Settings (Required)
ZOOM_VSDK_KEY="your_zoom_vsdk_key"
ZOOM_VSDK_SECRET="your_zoom_vsdk_secret"

# OpenAI API Settings (Optional - for AI responses)
OPENAI_API_KEY="sk-your_openai_api_key"

# Amazon Polly Settings (Optional - for high-quality speech synthesis)
# If not configured, will fallback to browser speech synthesis
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-northeast-1

# SpeechGen.io API Settings (for neutral voice synthesis)
SPEECHGEN_API_TOKEN="your_speechgen_api_token"
SPEECHGEN_EMAIL="your_speechgen_email@example.com"
SPEECHGEN_NEUTRAL_VOICE="Blue"

# Server Logs
# On AWS (ECS/Fargate), prefer stdout/stderr -> CloudWatch and disable file logging.
SERVER_LOG_TO_FILE=false
# Session Experiment Logs (Optional)
# Session logs are always written locally to ./logs/sessions.
# Enable S3 upload only when you want to collect logs centrally (e.g., on ECS).
# Options: file | s3
SESSION_LOG_UPLOAD_BACKEND=file
# If true, only uploads when running on AWS (ECS/EKS/etc). Default: true
SESSION_LOG_UPLOAD_ONLY_IF_AWS=true
# Required when SESSION_LOG_UPLOAD_BACKEND=s3
SESSION_LOG_S3_BUCKET=your-s3-bucket-name
# Optional prefix (default: logs/sessions)
SESSION_LOG_S3_PREFIX=logs/sessions
# Optional region (falls back to AWS_REGION)
# SESSION_LOG_S3_REGION=

## To specify how much history to include in AI prompt (to manage token limits), you can set:
# CHAT_HISTORY_MAX_ITEMS (default 20, max 50)
# CHAT_HISTORY_MAX_CHARS (default 6000)
# CHAT_HISTORY_MAX_CHARS_PER_ITEM (default 600)

# Notes:
# - System works without OpenAI API key (uses fallback responses)
# - System works without AWS Polly (uses browser speech synthesis)
# - Amazon Polly provides highest quality, most natural voices
# - Male agents automatically use Stephen (very natural US male neural voice)
# - Female agents automatically use Ruth (very natural US female neural voice)
# - Uses long-form neural engine for longer texts (100+ characters)
# - Automatically falls back to neural engine if long-form unavailable
# - Transcript language is set to English
# - AI responses are generated in English