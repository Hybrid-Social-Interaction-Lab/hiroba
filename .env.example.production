# Production environment template for the Caddy-fronted deploy
# (Docker Compose file: deploy/docker/docker-compose.caddy.yml)
#
# Copy this file to `.env.production` on the host that will run the app,
# fill in the values, then start the stack:
#
#   docker compose -f deploy/docker/docker-compose.caddy.yml \
#     --env-file .env.production up -d
#
# For local development use `.env.example` instead.

# --- HTTPS (Caddy) ---------------------------------------------------------
# Public hostname users will type in their browser.
# Required. Must already have a DNS A record pointing at this server's
# public IP *before* you start the stack — Caddy requests a Let's Encrypt
# cert on first boot and will be rate-limited if DNS isn't ready.
DOMAIN=hiroba.example.com

# Email used for Let's Encrypt registration (renewal notices).
ACME_EMAIL=admin@example.com

# --- App basics ------------------------------------------------------------
NODE_ENV=production
# Internal port. Caddy reverse-proxies to app:3000 over the compose network.
# Do not change unless you also update the Caddyfile.
PORT=3000

# --- Zoom Video SDK (required) --------------------------------------------
ZOOM_VSDK_KEY=your_zoom_vsdk_key
ZOOM_VSDK_SECRET=your_zoom_vsdk_secret

# --- OpenAI (optional, AI replies) ----------------------------------------
OPENAI_API_KEY=

# --- Amazon Polly (optional, high-quality TTS) ----------------------------
# Leave blank to fall back to browser speech synthesis.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-1

# --- SpeechGen.io (optional, neutral voice) -------------------------------
SPEECHGEN_API_TOKEN=
SPEECHGEN_EMAIL=
SPEECHGEN_NEUTRAL_VOICE=Blue

# --- Server logs ----------------------------------------------------------
# Use stdout/stderr so `docker logs caddy_app_1` works. File logs are still
# emitted to ./logs inside the container (mounted as a volume).
SERVER_LOG_TO_FILE=false

# --- Settings persistence -------------------------------------------------
# `file` writes to ./data/settings.json inside the container (mounted as a
# volume on the host). Set to `dynamodb` only if you've created a table.
SETTINGS_BACKEND=file
# SETTINGS_DDB_TABLE=
# SETTINGS_DDB_REGION=ap-northeast-1

# --- Session log persistence ----------------------------------------------
# `file` keeps logs in ./logs/sessions on the host volume. Set to `s3` if
# you want central upload (requires AWS credentials above + bucket below).
SESSION_LOG_UPLOAD_BACKEND=file
SESSION_LOG_UPLOAD_ONLY_IF_AWS=false
# SESSION_LOG_S3_BUCKET=
# SESSION_LOG_S3_PREFIX=logs/sessions

# --- AI prompt history limits (optional) ----------------------------------
# CHAT_HISTORY_MAX_ITEMS=20
# CHAT_HISTORY_MAX_CHARS=6000
# CHAT_HISTORY_MAX_CHARS_PER_ITEM=600
